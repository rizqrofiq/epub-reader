# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth & Drive
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
NEXT_PUBLIC_GOOGLE_API_KEY=your-google-api-key
NEXT_PUBLIC_GOOGLE_APP_ID=your-google-cloud-project-number

# Server-side ONLY — never add NEXT_PUBLIC_ prefix. Used to mint Drive access
# tokens from the stored refresh token in /api/drive/token.
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Cloudflare R2 (S3-compatible) — server-side ONLY, no NEXT_PUBLIC_ prefix.
# Create an R2 bucket + an S3 API token (Account ID, Access Key, Secret).
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=your-r2-bucket-name

# AI assistant (BYOK) — server-side ONLY. Used to AES-GCM encrypt users' API
# keys before storing them in Supabase. Must be base64 of exactly 32 random
# bytes. Generate: openssl rand -base64 32
AI_KEY_ENCRYPTION_KEY=your-base64-32-byte-key
# Optional quota guardrails (defaults: 500 books, 2 GB per user) to stay within
# R2's 10 GB free tier.
# R2_MAX_BOOKS_PER_USER=500
# R2_MAX_BYTES_PER_USER=2147483648
